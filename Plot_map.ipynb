    "# Define years for each climate phase\n",
    "warm1 = list(range(1999, 2006))     \n",
    "cold1 = list(range(2007, 2009))     \n",
    "warm2 = list(range(2010, 2013))     \n",
    "cold2 = list(range(2014, 2017))     \n",
    "warm3 = list(range(2018, 2024))    \n",
    "\n",
    "# Ensure the index is integer\n",
    "annual_hind.index = annual_hind.index.astype(int)\n",
    "\n",
    "# Calculate average for each climate phase\n",
    "hind_warm1 = annual_hind.loc[annual_hind.index.isin(warm1)].mean()\n",
    "hind_cold1 = annual_hind.loc[annual_hind.index.isin(cold1)].mean()\n",
    "hind_warm2 = annual_hind.loc[annual_hind.index.isin(warm2)].mean()\n",
    "hind_cold2 = annual_hind.loc[annual_hind.index.isin(cold2)].mean()\n",
    "hind_warm3 = annual_hind.loc[annual_hind.index.isin(warm3)].mean()\n",
    "\n",
    "# Combine into one DataFrame\n",
    "hind_phase = pd.DataFrame({\n",
    "    'warm1_avg': hind_warm1,\n",
    "    'cold1_avg': hind_cold1,\n",
    "    'warm2_avg': hind_warm2,\n",
    "    'cold2_avg': hind_cold2,\n",
    "    'warm3_avg': hind_warm3\n",
    "})\n",
    "\n",
    "# Keep only numeric columns\n",
    "vgpm_numeric = annual_vgpm.select_dtypes(include='number')\n",
    "\n",
    "# Calculate average for each climate phase\n",
    "vgpm_warm1 = vgpm_numeric.loc[vgpm_numeric.index.isin(warm1)].mean()\n",
    "vgpm_cold1 = vgpm_numeric.loc[vgpm_numeric.index.isin(cold1)].mean()\n",
