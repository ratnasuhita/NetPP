    "]\n",
    "\n",
    "# Loop to draw graphs for each subplot\n",
    "for i, place in enumerate(epu_name):\n",
    "    ax = axes[i // 3, i % 3]\n",
    "    \n",
    "    # Plot NPP on primary y-axis\n",
    "    ax.plot(annual_vgpm.index, annual_vgpm[place], label='npp_sat_vgpm', color='b')\n",
    "    ax.set_ylabel('NPP', fontsize=17, labelpad=12, color='b')\n",
    "    ax.tick_params(axis='y', labelcolor='b')\n",
    "\n",
    "    # Create second y-axis for Pb Opt\n",
    "    ax2 = ax.twinx()\n",
    "    ax2.plot(annual_pb1.index, annual_pb1[place], label='pb_opt1', color='g')\n",
    "    ax2.set_ylabel('Pb Opt', fontsize=17, labelpad=12, color='g')\n",
    "    ax2.tick_params(axis='y', labelcolor='g')\n",
    "\n",
    "    # Common X and title\n",
    "    ax.set_title(place, fontsize=20)\n",
    "    ax.set_xlabel('Year', fontsize=17, labelpad=12)\n",
    "    ax.tick_params(axis='both', which='major', labelsize=14)\n",
    "    ax.grid(True)\n",
    "\n",
    "# Super title and legend (custom manual legend below)\n",
    "fig.suptitle(r'Annual NPP vs Annual Pb Opt', fontsize=24, fontweight='bold', y=1.02)\n",
    "plt.tight_layout()\n",
    "\n",
    "# Manual legend creation since we used twin axes (not automatically combined)\n",
