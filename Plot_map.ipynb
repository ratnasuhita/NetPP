  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "6",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load datasets\n",
    "\n",
    "path = r'\\Users\\ratna\\OneDrive\\Documents\\NPP\\Temporary output\\npp_chl1.nc'\n",
