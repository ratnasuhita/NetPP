   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "7",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Compute annual net for NPP VGPM\n",
    "npp_vgpm = npp_chl['VGPM']\n",
    "vgpm = npp_vgpm.resample(time='YS').mean()*365/1000  # unit in grC/m2/year"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "8",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Compute annual net for NPP VGPM\n",
    "npp_evgpm = npp_chl['EVGPM']\n",
    "evgpm = npp_evgpm.resample(time='YS').mean()*365/1000  # unit in grC/m2/year"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "9",
   "metadata": {},
   "source": [
    "## Data extraction using EPU"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "10",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Initialize coords for NPP chl\n",
    "lat = npp_chl['latitude'].values\n",
    "lon = npp_chl['longitude'].values"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "11",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create dictionary of name and geometry for all EPU\n",
    "\n",
    "epus = dict(zip(name, geometry))\n",
    "epus"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "12",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create function to handle both Polygon or Multipolygons --> extract the exterior coordinates from a given geometry object\n",
    "\n",
    "def get_polygon_coords(geometry):\n",
    "    # If the geometry is polygon\n",
    "    if isinstance(geometry, Polygon):\n",
    "        return [(coord[0], coord[1]) for coord in geometry.exterior.coords]\n",
    "    \n",
    "    # If the geometry is multipolygon\n",
    "    elif isinstance(geometry, MultiPolygon):\n",
    "        coords = []\n",
    "        for poly in geometry.geoms:  # Use .geoms to access each polygon\n",
    "            coords.extend([(coord[0], coord[1]) for coord in poly.exterior.coords])\n",
    "        return coords"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "13",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Apply get_polygon_coords function to each EPU (to create polygons for each EPU)\n",
    "\n",
    "Labrador_Shelf_coords = get_polygon_coords(epus['Labrador Shelf'])\n",
    "Labrador_Shelf = Polygon(Labrador_Shelf_coords)\n",
    "\n",
    "NE_Newfoundland_Shelf_coords = get_polygon_coords(epus['Northeast Newfoundland Shelf'])\n",
    "NE_Newfoundland_Shelf = Polygon(NE_Newfoundland_Shelf_coords)\n",
    "\n",
    "Grand_Banks_coords = get_polygon_coords(epus['Grand Banks'])\n",
    "Grand_Banks = Polygon(Grand_Banks_coords)\n",
    "\n",
    "Scotian_Shelf_coords = get_polygon_coords(epus['Scotian Shelf'])\n",
    "Scotian_Shelf = Polygon(Scotian_Shelf_coords)\n",
    "\n",
    "Gulf_of_Maine_coords = get_polygon_coords(epus['Gulf of Maine'])\n",
    "Gulf_of_Maine = Polygon(Gulf_of_Maine_coords)\n",
    "\n",
    "Georges_Bank_coords = get_polygon_coords(epus[\"George's Bank\"])\n",
    "Georges_Bank = Polygon(Georges_Bank_coords)\n",
    "\n",
    "Mid_Atlantic_Bight_coords = get_polygon_coords(epus['Mid-Atlantic Bight'])\n",
    "Mid_Atlantic_Bight = Polygon(Mid_Atlantic_Bight_coords)\n",
    "\n",
    "Southern_Newfoundland_coords = get_polygon_coords(epus['Southern Newfoundland'])\n",
    "Southern_Newfoundland = Polygon(Southern_Newfoundland_coords)\n",
    "\n",
    "Flemish_Cap_coords = get_polygon_coords(epus['Flemish Cap'])\n",
    "Flemish_Cap = Polygon(Flemish_Cap_coords)\n",
    "\n",
    "# Display the results\n",
    "display(Labrador_Shelf)\n",
    "display(NE_Newfoundland_Shelf)\n",
    "display(Grand_Banks)\n",
    "display(Scotian_Shelf)\n",
    "display(Gulf_of_Maine)\n",
    "display(Georges_Bank)\n",
    "display(Mid_Atlantic_Bight)\n",
    "display(Southern_Newfoundland)\n",
    "display(Flemish_Cap)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "14",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create mask arrays for each EPU to track grid points inside of the polygon --> need latitude and longitude from dataset\n",
    "\n",
    "# NPP from chl\n",
    "Labrador_Shelf_mask = np.zeros((len(lat), len(lon)))*np.nan\n",
    "NE_Newfoundland_Shelf_mask = np.zeros((len(lat), len(lon)))*np.nan\n",
    "Grand_Banks_mask = np.zeros((len(lat), len(lon)))*np.nan\n",
    "Scotian_Shelf_mask = np.zeros((len(lat), len(lon)))*np.nan\n",
    "Gulf_of_Maine_mask = np.zeros((len(lat), len(lon)))*np.nan\n",
    "Georges_Bank_mask = np.zeros((len(lat), len(lon)))*np.nan\n",
    "Mid_Atlantic_Bight_mask = np.zeros((len(lat), len(lon)))*np.nan\n",
    "Southern_Newfoundland_mask = np.zeros((len(lat), len(lon)))*np.nan\n",
    "Flemish_Cap_mask = np.zeros((len(lat), len(lon)))*np.nan"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "15",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Counter\n",
    "\n",
    "Labrador_Shelf_counter = 0\n",
    "NE_Newfoundland_Shelf_counter = 0\n",
    "Grand_Banks_counter = 0\n",
    "Scotian_Shelf_counter = 0\n",
    "Gulf_of_Maine_counter = 0\n",
    "Georges_Bank_counter = 0\n",
    "Mid_Atlantic_Bight_counter = 0\n",
    "Southern_Newfoundland_counter = 0\n",
    "Flemish_Cap_counter = 0"
   ]
